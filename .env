# ============================================================================
# BANCO DE DADOS
# ============================================================================
# SQLite para desenvolvimento local
DATABASE_URL=sqlite:///./banco.db


# ============================================================================
# CONFIGURAÇÕES DE SEGURANÇA E JWT
# ============================================================================
# JWT - Chave secreta (GERAR UMA NOVA EM PRODUÇÃO!)
SECRET_KEY=LocalhostPassword
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ============================================================================
# RATE LIMITING (Requisições por hora)
# ============================================================================
# Limita tentativas de cadastro
RATE_LIMIT_REGISTER=2

# Limita tentativas de refresh token
RATE_LIMIT_REFRESH=4

# Limita tentativas de login
RATE_LIMIT_LOGIN=6

# Limita tentativas de recuperação de senha (todas as 3 etapas)
RATE_LIMIT_PASSWORD_RECOVERY=6