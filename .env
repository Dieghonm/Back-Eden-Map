
# ============================================================================
# BANCO DE DADOS
# ============================================================================
DATABASE_URL=sqlite:///./banco.db

# ============================================================================
# CONFIGURAÇÕES DE SEGURANÇA E JWT
# ============================================================================
SECRET_KEY=LocalhostPassword
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ============================================================================
# RATE LIMITING (Requisições por hora)
# ============================================================================
RATE_LIMIT_REGISTER=2
RATE_LIMIT_REFRESH=4
RATE_LIMIT_LOGIN=6
RATE_LIMIT_PASSWORD_RECOVERY=6

# ============================================================================
# BREVO EMAIL SERVICE
# ============================================================================
# Obtenha sua API key em: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=sua-api-key-aqui

# Email de origem (de quem os emails serão enviados)
BREVO_SENDER_EMAIL=duo.estudio.tech@gmail.com

# Nome de quem envia os emails
BREVO_SENDER_NAME=Eden Map

# Ativar/desativar envio de emails (true/false)
EMAIL_ENABLED=true